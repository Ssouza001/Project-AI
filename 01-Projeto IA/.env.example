# Copie este arquivo para ".env" e preencha a chave localmente.
# Nunca coloque a chave real no frontend ou em prints do projeto.

GOOGLE_FACTCHECK_API_KEY=
NEWS_API_KEY=
MEDIASTACK_API_KEY=
ADMIN_TOKEN=

# Opcional. O padrao do projeto e portugues.
GOOGLE_FACTCHECK_LANGUAGE=pt

# Opcional. Se vazio, o backend usa o threshold salvo em Modelo_V3/artifacts/reports/metrics.json.
MODEL_CONFIDENCE_THRESHOLD_TO_MIXED=

# Auto-retreino seguro. Usa apenas candidatos trusted_true_ready/approved_true
# e so promove o modelo novo se ele passar nos gates de qualidade.
AUTO_RETRAIN_ENABLED=false
AUTO_RETRAIN_INTERVAL_HOURS=24
AUTO_RETRAIN_MIN_CANDIDATES=1
